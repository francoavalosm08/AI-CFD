# Copy this file to .env before running Docker Compose.

# Required for Foam-Agent when using the OpenAI provider.
OPENAI_API_KEY=sk-your-key-here

# Use "mcp" for real Foam-Agent/OpenFOAM runs or "fake" for UI/backend smoke tests.
FOAM_AGENT_MODE=mcp

# Foam-Agent model settings passed to the foamagent container.
FOAMAGENT_MODEL_PROVIDER=openai
FOAMAGENT_MODEL_VERSION=gpt-5.4
