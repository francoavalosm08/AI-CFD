# Copy this file to .env only when running optional Foam-Agent/OpenFOAM MCP mode.
# The planned local OpenFOAM V1 path should not require this file or an API key.

# Required only for Foam-Agent when using the OpenAI provider.
OPENAI_API_KEY=sk-your-key-here

# Use "fake" for fast local regression tests or "mcp" for optional Foam-Agent/OpenFOAM runs.
FOAM_AGENT_MODE=fake

# Primary no-API local OpenFOAM path. These do not require OPENAI_API_KEY.
CFD_RUNNER_MODE=fake
OPENFOAM_RUNTIME=wsl
OPENFOAM_WSL_DISTRO=Ubuntu
OPENFOAM_BASHRC=/opt/openfoam*/etc/bashrc
OPENFOAM_RUN_TIMEOUT_SECONDS=1200
OPENFOAM_DRY_RUN=0

# Local MCP endpoint when Foam-Agent Docker is running on the host.
FOAM_AGENT_URL=http://127.0.0.1:7860/mcp

# Container-visible shared data roots used by prompts and artifact mirroring.
FOAM_AGENT_SHARED_AGENT_ROOT=/workspace/data
FOAM_AGENT_AGENT_RUNS_ROOT=/home/openfoam/Foam-Agent/runs

# Host path that mirrors /home/openfoam/Foam-Agent/runs from the Foam-Agent container.
# Example Windows path:
# FOAM_AGENT_APP_RUNS_ROOT=C:\Users\franc\OneDrive\Desktop\AI CFD\data\foamagent-runs
FOAM_AGENT_APP_RUNS_ROOT=

# Solver timeout passed to Foam-Agent run tool calls.
FOAM_AGENT_RUN_TIMEOUT_SECONDS=900

# Foam-Agent model settings passed to the foamagent container.
FOAMAGENT_MODEL_PROVIDER=openai
FOAMAGENT_MODEL_VERSION=gpt-5.4
